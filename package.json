{
  "name": "starlabs",
  "version": "1.0.0",
  "description": "Starlight Labs - AI-native global talent & delivery platform",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --watch",
    "test:ci": "jest --coverage",
    "format": "prettier --write .",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "generate": "prisma generate",
    "load:artillery": "artillery run artillery.yml",
    "load:k6": "k6 run load-tests/k6-script.js",
    "load:autocannon": "autocannon -c load-tests/autocannon-config.js http://localhost:3000"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.0",
    "@types/node": "^20.11.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "@prisma/client": "^5.8.0",
    "prisma": "^5.8.0",
    "zod": "^3.22.0",
    "stripe": "^14.10.0",
    "twilio": "^4.10.0",
    "resend": "^3.0.0",
    "axios": "^1.6.0",
    "swr": "^2.2.0",
    "zustand": "^4.4.0",
    "clsx": "^2.0.0",
    "tailwind-merge": "^2.2.0",
    "dotenv": "^16.3.0",
    "pg": "^8.11.0",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "eslint-config-next": "^14.2.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/user-event": "^14.5.0",
    "ts-jest": "^29.1.0",
    "artillery": "^2.0.0",
    "autocannon": "^7.10.0",
    "swagger-ui-react": "^5.11.0"
  },
  "engines": {
    "node": ">=18.17"
  }
}
