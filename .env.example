# Copy to .env.local and adjust values.

# Database (required) — matches docker-compose postgres service by default
DATABASE_URL=postgresql://starlabs:starlabs_dev_password@localhost:5432/starlabs

REDIS_URL=redis://localhost:6379

# Auth (use long random strings in production)
JWT_SECRET=dev-jwt-secret-change-me-min-32-chars-please
SESSION_SECRET=dev-session-secret-change-me
ADMIN_SECRET=dev-admin-secret
CRON_SECRET=dev-cron-secret

# Public URL for browser-side API calls (optional; empty = same-origin)
NEXT_PUBLIC_API_URL=

# Stripe (optional — mock for local)
STRIPE_SECRET_KEY=sk_test_mock
STRIPE_PUBLIC_KEY=pk_test_mock
STRIPE_WEBHOOK_SECRET=whsec_mock

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@starlabs.dev

NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=Starlight Labs
