# Database
DATABASE_URL=postgresql://user:password@localhost:5432/starlabs

# Redis (for caching)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your-jwt-secret-key-change-in-production
SESSION_SECRET=your-session-secret-key-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Twilio (SMS, WhatsApp, Voice)
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+1234567890
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Resend (Email)
RESEND_API_KEY=re_xxx

# Cerebras (LLM API)
CEREBRAS_API_KEY_1=csk_xxx
CEREBRAS_API_KEY_2=csk_xxx
CEREBRAS_API_KEY_3=csk_xxx

# n8n (Workflow automation)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/

# Application
NODE_ENV=development
APP_URL=http://localhost:3000
APP_NAME=Starlight Labs

# Admin
ADMIN_SECRET=change-this-in-production
EOF

cat > /tmp/starlabs/.gitignore << 'GITIGNORE_EOF'
node_modules/
.next/
.env
.env.local
.env.*.local
*.log
.DS_Store
dist/
build/
.prisma/
.vercel
out/
.idea/
*.swp
*.swo
GITIGNORE_EOF

echo "✓ Environment files created"
